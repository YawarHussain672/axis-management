# ─────────────────────────────────────────────────────────────────────────────
# Axis Max Life — Print Management System
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection string
# Use the "Pooled connection" string for production
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true&connect_timeout=15"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# NEXTAUTH_URL must match your deployment URL exactly
NEXTAUTH_URL="http://localhost:3000"

# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=""

# ─── Cloudinary (File Uploads — PO, Challan, Invoice) ────────────────────────
# Get from: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Pusher (Real-time Notifications) ────────────────────────────────────────
# Get from: https://dashboard.pusher.com
NEXT_PUBLIC_PUSHER_APP_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"
PUSHER_APP_ID=""
PUSHER_SECRET=""

# ─── App Settings ────────────────────────────────────────────────────────────
# Used during database seeding only
ADMIN_EMAIL="youremail@.com"
ADMIN_PASSWORD="yourpass@123"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="Axis Print Management <noreply@yourdomain.com>"
