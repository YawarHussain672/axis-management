generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  name       String
  phone      String?
  password   String
  role       UserRole   @default(POC)
  location   String?
  branch     String?
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  activities Activity[]
  approvals  Approval[]
  projects   Project[]

  @@map("users")
}

model Project {
  id             String          @id @default(cuid())
  projectId      String          @unique
  name           String
  piNumber       String?
  location       String
  state          String?
  deliveryDate   DateTime
  status         ProjectStatus   @default(REQUESTED)
  totalCost      Float           @default(0)
  instructions   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  pocId          String
  branch         String?
  leadsConverted Int?
  leadsGenerated Int?
  approval       Approval?
  collaterals    Collateral[]
  dispatch       Dispatch?
  files          FileUpload[]
  poc            User            @relation(fields: [pocId], references: [id])
  statusHistory  StatusHistory[]

  @@map("projects")
}

model Collateral {
  id            String  @id @default(cuid())
  projectId     String
  itemName      String
  quantity      Int
  unitPrice     Float
  totalPrice    Float
  specification String?
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("collaterals")
}

model StatusHistory {
  id          String        @id @default(cuid())
  projectId   String
  status      ProjectStatus
  note        String?
  timestamp   DateTime      @default(now())
  changedById String?
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("status_history")
}

model FileUpload {
  id           String   @id @default(cuid())
  projectId    String
  type         FileType
  url          String
  filename     String
  size         Int?
  uploadedAt   DateTime @default(now())
  uploadedById String?
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("file_uploads")
}

model Approval {
  id            String         @id @default(cuid())
  projectId     String         @unique
  status        ApprovalStatus @default(PENDING)
  requestedById String
  approvedById  String?
  approvedAt    DateTime?
  rejectedAt    DateTime?
  notes         String?
  reminderCount Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy   User           @relation(fields: [requestedById], references: [id])

  @@map("approvals")
}

model Dispatch {
  id               String    @id @default(cuid())
  projectId        String    @unique
  courier          String
  trackingId       String
  trackingUrl      String?
  dispatchDate     DateTime?
  expectedDelivery DateTime?
  actualDelivery   DateTime?
  status           String    @default("in_transit")
  podUrl           String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("dispatches")
}

model RateCard {
  id            String   @id @default(cuid())
  itemName      String   @unique
  specification String
  volumeSlabs   Json
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("rate_cards")
}

model Activity {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("activities")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

enum UserRole {
  ADMIN
  POC
}

enum ProjectStatus {
  REQUESTED
  APPROVED
  PRINTING
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FileType {
  PO
  CHALLAN
  INVOICE
  POD
}
